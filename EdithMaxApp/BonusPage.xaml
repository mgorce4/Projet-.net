<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:EdithMaxApp.ViewModels"
             xmlns:models="clr-namespace:EdithMaxApp.Models"
             x:DataType="viewModels:BonusPageViewModel"
             x:Class="EdithMaxApp.BonusPage"
             Title="Bonus - Carrousel">
    <Grid RowDefinitions="Auto, *, Auto" Padding="10" RowSpacing="10">
        <!-- Titre -->
        <Label Grid.Row="0"
               Text="Carrousel de dinosaures"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <!-- CarouselView -->
        <CarouselView Grid.Row="1" 
                      ItemsSource="{Binding DinosaurImages}">
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="models:DinosaurImage">
                    <StackLayout>
                        <Border Stroke="DarkGray"
                                StrokeShape="RoundRectangle 5"
                                Margin="20"
                                Padding="20"
                                HeightRequest="360"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">            
                            <StackLayout>
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                                <Image Source="{Binding ImageURL}"
                                       Aspect="AspectFill"
                                       HeightRequest="150"
                                       WidthRequest="150"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Author}"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Description}"
                                       FontAttributes="Italic"
                                       HorizontalOptions="Center"
                                       MaxLines="5"
                                       LineBreakMode="TailTruncation" />
                            </StackLayout>
                        </Border>
                    </StackLayout>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- ActivityIndicator -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" VerticalOptions="Center" />

        <!-- Erreur -->
        <Label Grid.Row="2" Text="{Binding ErrorMessage}" IsVisible="{Binding ErrorMessage}" TextColor="Red" HorizontalOptions="Center" LineBreakMode="WordWrap" />
        
    </Grid>
    
</ContentPage>
