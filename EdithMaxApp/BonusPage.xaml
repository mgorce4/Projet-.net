<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:EdithMaxApp.ViewModels"
             xmlns:models="clr-namespace:EdithMaxApp.Models"
             x:DataType="viewModels:BonusPageViewModel"
             x:Class="EdithMaxApp.BonusPage"
             Title="Bonus - Carrousel">
    <ScrollView>
        <StackLayout Spacing="20" Padding="10">
            <!-- Titre -->
            <Label Text="Carrousel de dinosaures"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- CarouselView -->
            <CarouselView ItemsSource="{Binding DinosaurImages}"
                          HeightRequest="400">
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="models:DinosaurImage">
                    <StackLayout>
                        <Border Stroke="DarkGray"
                                StrokeShape="RoundRectangle 5"
                                Margin="20"
                                Padding="20"
                                HeightRequest="360"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">            
                            <StackLayout>
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                                <Image Source="{Binding ImageURL}"
                                       Aspect="AspectFill"
                                       HeightRequest="150"
                                       WidthRequest="150"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Author}"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Description}"
                                       FontAttributes="Italic"
                                       HorizontalOptions="Center"
                                       MaxLines="5"
                                       LineBreakMode="TailTruncation" />
                            </StackLayout>
                        </Border>
                    </StackLayout>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- ActivityIndicator -->
        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" VerticalOptions="Center" />

        <!-- Erreur -->
        <Label Text="{Binding ErrorMessage}" IsVisible="{Binding ErrorMessage}" TextColor="Red" HorizontalOptions="Center" LineBreakMode="WordWrap" />
        
        <!-- Titre Dinosaure Aléatoire -->
        <Label Text="Dinosaure Aléatoire"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <!-- Dinosaure Aléatoire Section -->
        <StackLayout Spacing="15" Padding="10">
            <!-- Image -->
            <Frame BorderColor="DarkGray"
                   CornerRadius="10"
                   Padding="0"
                   HorizontalOptions="Center"
                   HasShadow="True">
                <Image Source="{Binding RandomDinosaur.ImageURL}"
                       Aspect="AspectFill"
                       HeightRequest="200"
                       WidthRequest="200"
                       HorizontalOptions="Center" />
            </Frame>

            <!-- Titre -->
            <Label Text="{Binding RandomDinosaur.Title}"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Description -->
            <Label Text="{Binding RandomDinosaur.Description}"
                   FontSize="12"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"
                   MaxLines="4" />

            <!-- Bouton Dé -->
            <Button Command="{Binding LoadNewRandomDinosaurCommand}"
                    Text="🎲"
                    Style="{StaticResource DinoButtonStyle}"/>
        </StackLayout>
        </StackLayout>
    </ScrollView>
</ContentPage>
