<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:EdithMaxApp.ViewModels"
             xmlns:converters="clr-namespace:EdithMaxApp.Converters"
             xmlns:models="clr-namespace:EdithMaxApp.Models"
             x:DataType="viewModels:GalleryViewModel"
             x:Class="EdithMaxApp.GalleryPage"
             Title="Galerie des Dinosaures">
    <ContentPage.Resources>
        <converters:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Padding="10" ColumnSpacing="10" RowSpacing="10">
        <!-- Titre -->
        <Label Grid.Row="0"
               Text="Galerie des Dinosaures"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <!-- CollectionView : 1 colonne -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding DinosaurImages}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:DinosaurImageItemViewModel">
                    <Frame Padding="10" Margin="5" CornerRadius="10" BorderColor="#D0D0D0" HasShadow="True">
                        <VerticalStackLayout Spacing="8">
                            <!-- Image -->
                            <Image Source="{Binding Image.ImageURL}" Aspect="AspectFill" HeightRequest="250" HorizontalOptions="FillAndExpand" />
                            
                            <!-- Titre (clickable) -->
                            <Label Text="{Binding Image.Title}" 
                                   FontAttributes="Bold" 
                                   FontSize="18" 
                                   LineBreakMode="TailTruncation"
                                   TextColor="Black"
                                   Padding="10"
                                   BackgroundColor="#F5F5F5">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleDescriptionCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                            
                            <!-- Description (toggle) -->
                            <Label Text="{Binding Image.Description}" 
                                   FontSize="14" 
                                   Opacity="0.85"
                                   TextColor="#333333"
                                   Padding="10"
                                   LineBreakMode="WordWrap" 
                                   IsVisible="{Binding IsDescriptionVisible}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ActivityIndicator -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" VerticalOptions="Center" />

        <!-- Erreur -->
        <Label Grid.Row="2" Text="{Binding ErrorMessage}" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}" TextColor="Red" HorizontalOptions="Center" LineBreakMode="WordWrap" />
    </Grid>
</ContentPage>

