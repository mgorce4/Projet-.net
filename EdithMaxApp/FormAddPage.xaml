<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EdithMaxApp.FormAddPage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <Label Text="Formulaire d'ajout" HorizontalOptions="Center" FontSize="24" FontAttributes="Bold" />
            
            <Label Text="Titre" FontSize="16" FontAttributes="Bold" />
            <Entry x:Name="TitreEntry" Placeholder="Entrez le titre" />
            
            <Label Text="Description" FontSize="16" FontAttributes="Bold" />
            <Editor x:Name="DescriptionEditor" Placeholder="Entrez la description" HeightRequest="120" />
            
            <Label Text="Image" FontSize="16" FontAttributes="Bold" />
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Button Text="Choisir une image de la galerie" Style="{StaticResource SmallerDinoButtonStyle}"/>
                <Button Text="Prendre une photo" Style="{StaticResource SmallerDinoButtonStyle}"/>
            </HorizontalStackLayout>
            
            <Button Text="Sauvegarder" Style="{StaticResource DinoButtonStyle}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
